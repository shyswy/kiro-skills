# ============================
# Private Convention: underscore prefix (_)
# Skills and steering starting with _ are private (company-specific)
# ============================

# Private skills/dirs (company-specific, eval workspace, drafts)
# Convention: _ prefix = private, anywhere under skills/
skills/**/_*/

# Private steering (company-specific config)
steering/_*.md

# Private scripts (company-specific)
scripts/_*

# ============================
# Sensitive / Local-only
# ============================

# MCP settings (contains tokens/secrets)
settings/

# History (local session data)
history/

# Tasks (personal work tracking, JIRA metadata)
tasks/

# Personal notes (learning notes, not for public)
notes/

# Powers (local runtime)
powers/

# Extensions (installed per environment)
extensions/

# Planning docs (may contain company specifics)
user-scope-plan.md
UPGRADE-PLAN.md
BEST-PRACTICE-UPGRADE.md

# ============================
# General
# ============================

# Log files
*.log

# OS files
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~
