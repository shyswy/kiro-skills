# ============================
# Private Convention: underscore prefix (_)
# Skills and steering starting with _ are private (company-specific)
# ============================

# Private skills (company-specific, not for public)
skills/_*/

# Private steering (company-specific config)
steering/_*.md

# ============================
# Sensitive / Local-only
# ============================

# MCP settings (contains tokens/secrets)
settings/

# History (local session data)
history/

# Powers (local runtime)
powers/

# Extensions (installed per environment)
extensions/

# Planning docs (may contain company specifics)
user-scope-plan.md
UPGRADE-PLAN.md
BEST-PRACTICE-UPGRADE.md

# ============================
# General
# ============================

# Log files
*.log

# OS files
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~
